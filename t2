def create_linear_layer(
    input_size=256,
    output_size=128,
    weight_dtype=torch.int8,
    has_weight_scale=True,
    has_weight_offset=True,
    has_input_scale=False,
    has_input_offset=False,
    has_deq_scale=False,
    has_quant_bias=False,
    has_weight_scale_second=False,
    has_weight_offset_second=False,
    params_dtype=torch.bfloat16,
):
    layer = torch.nn.Module()
    layer.weight = torch.nn.Parameter(
        torch.randint(-128, 127, (output_size, input_size), dtype=weight_dtype),
        requires_grad=False,
    )

    if has_weight_scale:
        layer.weight_scale = torch.nn.Parameter(
            torch.randn(output_size, 1, dtype=params_dtype), requires_grad=False
        )

    if has_weight_offset:
        layer.weight_offset = torch.nn.Parameter(
            torch.randn(output_size, 1, dtype=params_dtype), requires_grad=False
        )

    if has_input_scale:
        layer.input_scale = torch.nn.Parameter(
            torch.randn(1, dtype=params_dtype), requires_grad=False
        )

    if has_input_offset:
        layer.input_offset = torch.nn.Parameter(
            torch.zeros(1, dtype=torch.int8), requires_grad=False
        )

    if has_deq_scale:
        layer.deq_scale = torch.nn.Parameter(
            torch.randn(output_size, dtype=torch.float32), requires_grad=False
        )

    if has_quant_bias:
        layer.quant_bias = torch.nn.Parameter(
            torch.randn(output_size, dtype=torch.int32), requires_grad=False
        )

    if has_weight_scale_second:
        group_size = 256
        layer.weight_scale_second = torch.nn.Parameter(
            torch.randn(output_size, input_size // group_size, dtype=params_dtype), requires_grad=False
        )

    if has_weight_offset_second:
        group_size = 256
        layer.weight_offset_second = torch.nn.Parameter(
            torch.randn(output_size, input_size // group_size, dtype=params_dtype), requires_grad=False
        )

    return layer


def create_moe_layer(
    num_experts=8,
    hidden_size=128,
    intermediate_size=128,
    weight_dtype=torch.int8,
    params_dtype=torch.bfloat16,
):
    layer = torch.nn.Module()
    layer.w13_weight = torch.nn.Parameter(
        torch.randint(-8, 8, (num_experts, 2 * intermediate_size, hidden_size), dtype=weight_dtype),
        requires_grad=False,
    )
    layer.w2_weight = torch.nn.Parameter(
        torch.randint(-8, 8, (num_experts, hidden_size, intermediate_size), dtype=weight_dtype),
        requires_grad=False,
    )
    layer.w13_weight_scale = torch.nn.Parameter(
        torch.ones((num_experts, 2 * intermediate_size, 1), dtype=params_dtype), requires_grad=False
    )
    layer.w13_weight_offset = torch.nn.Parameter(
        torch.zeros((num_experts, 2 * intermediate_size, 1), dtype=params_dtype), requires_grad=False
    )
    layer.w2_weight_scale = torch.nn.Parameter(
        torch.ones((num_experts, hidden_size, 1), dtype=params_dtype), requires_grad=False
    )
    layer.w2_weight_offset = torch.nn.Parameter(
        torch.zeros((num_experts, hidden_size, 1), dtype=params_dtype), requires_grad=False
    )
    return layer



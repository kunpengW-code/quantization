def model_uses_w4a4_quant(vllm_config: VllmConfig | None) -> bool:
    """Check whether the model uses W4A4 quantization for any layer.

    W4A4 schemes (e.g. W4A4_MXFP4, W4A4_DYNAMIC, W4A4_FLATQUANT_DYNAMIC,
    W4A4_MXFP4_FLATQUANT) are incompatible with the fuse_norm_quant
    optimization, so callers use this to disable that fusion.
    """
    if vllm_config is None:
        return False
    quant_config = getattr(vllm_config, "quant_config", None)
    if quant_config is None:
        return False
    quant_description = getattr(quant_config, "quant_description", None)
    if not quant_description:
        return False
    return any(
        isinstance(quant_type, str) and quant_type.startswith("W4A4")
        for quant_type in quant_description.values()
    )


